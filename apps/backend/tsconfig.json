{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "outDir": "dist",
    "baseUrl": "src",
    "paths": {
      "@shared/*": [
        "../../packages/shared/src/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}