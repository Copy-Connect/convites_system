{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2019",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "outDir": "./dist",
    "skipLibCheck": true
  },
  "include": [
    "src/main.ts",
    "src/app.module.ts",
    "src/prisma/**/*.ts",
    "src/payments/**/*.ts",
    "src/invite/**/*.ts",
    "src/types/**/*.d.ts"
  ]
}
