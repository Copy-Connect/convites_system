{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "Node",
    "types":["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "outDir": "dist",
    "baseUrl": "src",
    "paths": {
      "@shared/*": [
        "../../packages/shared/src/*"
      ]
    }
  },
  "include": ["src", "prisma/**/*.ts"] 
}