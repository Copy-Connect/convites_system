{
 "compilerOptions": {
    "target": "es2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "outDir": "./dist",
    "baseUrl": "./src",
    "types": ["node", "express"]
  },
  "include": [
    "src/main.ts",
    "src/app.module.ts",
    "src/prisma/**/*.ts",
    "src/payments/**/*.ts",
    "src/invite/**/*.ts",
    "src/types/**/*.d.ts"
, "src/payments/payments-.module.ts"  ],

  "exclude": ["node_modules", "dist"]
}
