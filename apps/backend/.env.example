# .env.example — backend (SQLite)
NODE_ENV=development
PORT=3000

# SQLite local (arquivo dentro da pasta prisma/)
DATABASE_URL="file:./prisma/dev.db"

# JWT
JWT_SECRET="troque-por-uma-chave-bem-grande-e-secreta"

# PagSeguro
PAGSEGURO_ENV=sandbox
PAGSEGURO_TOKEN="cole_seu_token_aqui"

# URL pública do Frontend
BASE_URL="https://convites.copyconnect.com.br"
