generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
  GENERATED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  orders    Order[]
  createdAt DateTime @default(now())
}

model Theme {
  slug   String @id
  title  String
}

model Order {
  id         Int         @id @default(autoincrement())
  userId     Int
  user       User        @relation(fields: [userId], references: [id])
  name       String
  age        Int
  address    String
  themeSlug  String
  theme      Theme       @relation(fields: [themeSlug], references: [slug])
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  payment    Payment?
}

model Payment {
  id            Int      @id @default(autoincrement())
  orderId       Int      @unique
  order         Order    @relation(fields: [orderId], references: [id])
  provider      String   // "pagseguro"
  transactionId String   @unique
  status        String   // "CREATED" | "PAID" | ...
  amountCents   Int
  createdAt     DateTime @default(now())
}
