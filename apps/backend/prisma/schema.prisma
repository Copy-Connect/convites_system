// apps/backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Theme {
 id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  bgUrl     String?
  musicUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

model Order {
  id String @id @default(cuid())

  // relação com usuário
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // relação (opcional) com tema
  themeId String?
  theme   Theme?  @relation(fields: [themeId], references: [id])

  // valor em centavos para evitar problemas de ponto flutuante
  amountCents Int

  /// Status como string (SQLite não tem enum no Prisma).
  /// Válidos: 'PENDING' | 'AUTHORIZED' | 'CANCELED' | 'IN_ANALYSIS' | 'PAID'
  status String @default("PENDING")

  // 1:1 com Payment (FK fica em Payment)
  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id String @id @default(cuid())

  /// Método como string: 'PIX' | 'CARD'
  method String @default("PIX")

  /// Status como string: 'PAYMENT_PENDING' | 'PAYMENT_AUTHORIZED' | 'PAYMENT_PAID' | 'PAYMENT_CANCELED'
  status String @default("PAYMENT_PENDING")

  amountCents Int

  // 1:1 com Order (FK única)
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
